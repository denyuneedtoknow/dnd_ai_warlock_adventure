{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "devCommand": null,
  "rewrites": [
    { "source": "/", "destination": "/pages/index.html" },
    {
      "source": "/(index|character|inventory|spells|npcs|journal|admin|play|wild-magic).html",
      "destination": "/pages/$1.html"
    }
  ],
  "functions": {
    "api/chat.js": {
      "maxDuration": 60
    },
    "api/save-session.js": {
      "maxDuration": 30
    }
  }
}
